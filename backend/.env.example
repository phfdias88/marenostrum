APP_ENV=production
APP_NAME=MareNostrum API

# Postgres (deve bater com docker-compose.yml)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=marenostrum
POSTGRES_USER=marenostrum
POSTGRES_PASSWORD=changeme

# JWT
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - libere apenas as origens que vao consumir a API.
# Em modo IP (sem dominio ainda), basta o proprio IP. Inclua localhost pra dev.
CORS_ORIGINS=["http://72.60.248.41","http://localhost:3000"]
