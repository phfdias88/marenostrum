# =====================================================================
# Variaveis lidas pelo docker-compose.yml (raiz).
# Estas sao injetadas em BUILD TIME no container `web` (Next.js inlinha
# NEXT_PUBLIC_* no bundle do cliente — nao tem como pegar em runtime).
#
# Pra subir: copie pra .env e ajuste com a URL real.
#   cp .env.example .env
# =====================================================================

# Onde o navegador vai chamar a API. SEMPRE via Nginx (porta 80/443).
# Em modo IP (sem dominio):
NEXT_PUBLIC_API_URL=http://72.60.248.41/api

# Quando configurar dominio + HTTPS:
# NEXT_PUBLIC_API_URL=https://app.marenostrum.com.br/api

# Integracoes externas embutidas em iframes (Fase 7).
# Deixe nos placeholders ate' o cliente real informar as URLs.
NEXT_PUBLIC_ANALYTICS_URL=https://example.com/analytics
NEXT_PUBLIC_SONAR_URL=https://example.com/sonar
