# URL publica que o navegador usa para chamar a API.
# Em modo IP, vai via Nginx (porta 80) -> /api -> container 'api'.
# Quando trocar para dominio, basta editar aqui.
NEXT_PUBLIC_API_URL=http://72.60.248.41/api

# ----------------------------------------------------------------------
# Integracoes externas embutidas no Super App (iframes)
# ----------------------------------------------------------------------
# IMPORTANTE: os sistemas externos devem permitir embedding via cabecalho
# Content-Security-Policy: frame-ancestors <origem-do-marenostrum>
# OU X-Frame-Options: ALLOWALL/SAMEORIGIN. Se o servidor externo bloquear
# embed, o iframe fica em branco — checar console.

# Dashboard de analise de votacoes (Looker / Metabase / Power BI / ...)
NEXT_PUBLIC_ANALYTICS_URL=https://example.com/analytics

# Sistema Sonar de atendimentos
NEXT_PUBLIC_SONAR_URL=https://example.com/sonar
